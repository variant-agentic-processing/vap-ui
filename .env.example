# GCP project ID — required for poe build and poe deploy
GCP_PROJECT=variant-processing

# Pulumi passphrase file — required for poe deploy
PULUMI_CONFIG_PASSPHRASE_FILE=/path/to/passphrase-file

# Workflow service base URL (server-side only — proxied via /api/workflow)
# Local dev: http://localhost:8080
# Deployed (VPN required): https://workflow-service-fno64g2krq-uc.a.run.app
WORKFLOW_SERVICE_URL=http://localhost:8080

# Agent service base URL (server-side only — proxied via /api/agent)
# Local dev: http://localhost:8081
# Deployed (VPN required): https://agent-service-fno64g2krq-uc.a.run.app
AGENT_SERVICE_URL=http://localhost:8081

# MCP variant server (for dashboard REST endpoints — proxied via /api/mcp)
# Local dev: http://localhost:8082
# Deployed (VPN required): https://mcp-variant-server-fno64g2krq-uc.a.run.app
MCP_SERVER_URL=http://localhost:8082
